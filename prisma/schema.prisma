generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id        String   @id @default(cuid())
  owner     String
  repo      String
  commitSha String
  result    Json
  createdAt DateTime @default(now())
  viewCount Int      @default(0)

  @@unique([owner, repo, commitSha])
  @@index([owner, repo])
}
